---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiveExperimentFrame from '../../components/LiveExperimentFrame';
import type { Experiment } from '../../lib/experiments';
import { getAllExperiments } from '../../lib/experiments';

export function getStaticPaths() {
  return getAllExperiments().map((experiment) => ({
    params: { version: experiment.version },
    props: { experiment }
  }));
}

const { experiment } = Astro.props as { experiment: Experiment };
---

<BaseLayout title={`${experiment.title} | Codex Frontend Lab`} description={experiment.hypothesis}>
  <section class="container page-head">
    <p class="eyebrow">{experiment.version}</p>
    <h1>{experiment.title}</h1>
    <p>{experiment.hypothesis}</p>
    <div class="meta-row">
      <p><strong>Mutation axis:</strong> {experiment.mutationAxis}</p>
      <p><strong>Score:</strong> {experiment.scoreOutOf20 !== null ? `${experiment.scoreOutOf20.toFixed(1)} / 20` : 'Not available'}</p>
      <p><strong>Decision:</strong> {experiment.keepDrop}</p>
    </div>
  </section>

  <section class="container">
    <LiveExperimentFrame
      client:load
      version={experiment.version}
      appHomeUrl={experiment.appHomeUrl}
      routes={experiment.routes}
      initialRouteId="1"
    />
  </section>

  <section class="container route-grid" aria-label="Route Results">
    {
      experiment.routes.map((route) => (
        <article class="route-card">
          <a href={`/experiments/${experiment.version}/${route.slug}`} aria-label={`${experiment.version} route ${route.id}`}>
            {route.screenshot ? (
              <img src={route.screenshot} alt={`${experiment.title} route ${route.path}`} loading="lazy" />
            ) : (
              <div class="missing-shot">Screenshot missing</div>
            )}
          </a>
          <div class="route-info">
            <h2>Route {route.path}</h2>
            <a href={`/experiments/${experiment.version}/${route.slug}`} class="inline-link">Open detailed view</a>
          </div>
        </article>
      ))
    }
  </section>

  <section class="container link-strip">
    <a href={experiment.readmePath} target="_blank" rel="noreferrer">Open README source</a>
    {experiment.critiquesPath ? (
      <a href={experiment.critiquesPath} target="_blank" rel="noreferrer">Open critique notes</a>
    ) : null}
    <a href="/experiments">Back to all versions</a>
  </section>
</BaseLayout>
