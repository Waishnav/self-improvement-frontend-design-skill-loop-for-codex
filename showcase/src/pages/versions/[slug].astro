---
import Base from "../../layouts/Base.astro";
import {
  versions,
  screenshotPath,
  dimensionLabels,
  type VersionMeta,
} from "../../data/versions";

export function getStaticPaths() {
  return versions.map((v) => ({
    params: { slug: v.slug },
    props: { version: v },
  }));
}

interface Props {
  version: VersionMeta;
}

const { version: v } = Astro.props;

const idx = versions.findIndex((x) => x.slug === v.slug);
const prev = idx > 0 ? versions[idx - 1] : null;
const next = idx < versions.length - 1 ? versions[idx + 1] : null;
const routes = Array.from({ length: v.routes }, (_, i) => i + 1);
---

<Base title={`${v.slug} — Skill Lab`} description={v.hypothesis}>
  {/* ── Header ── */}
  <section class="border-b border-white/[0.06]">
    <div class="mx-auto max-w-[90rem] px-6 py-10 lg:px-10">
      <a
        href="/"
        class="mb-6 inline-flex items-center gap-1.5 text-xs text-[var(--color-ink-2)] transition-colors hover:text-[var(--color-ink-0)]"
      >
        <svg class="size-3.5" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        Back to gallery
      </a>

      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <div class="mb-3 flex items-center gap-3">
            <h1
              class="font-[var(--font-heading)] text-4xl tracking-tight text-[var(--color-ink-0)] lg:text-5xl"
            >
              {v.slug}
            </h1>
            <span
              class="rounded bg-[var(--color-surface-3)] px-2.5 py-1 text-[11px] font-medium uppercase tracking-wider text-[var(--color-ink-2)]"
            >
              {v.mutationAxis}
            </span>
          </div>
          <p class="text-base leading-relaxed text-[var(--color-ink-1)]">
            {v.hypothesis}
          </p>
        </div>

        {/* score card */}
        {v.score !== null && (
          <div class="shrink-0 rounded-lg border border-white/[0.06] bg-[var(--color-surface-1)] p-5">
            <p class="mb-1 text-xs uppercase tracking-wider text-[var(--color-ink-2)]">
              Rubric Score
            </p>
            <p class="text-4xl font-bold tabular-nums text-[var(--color-accent-glow)]">
              {v.score}<span class="text-lg text-[var(--color-ink-2)]"> / 20</span>
            </p>
            {v.delta && (
              <p class="mt-1 text-sm font-medium tabular-nums text-[var(--color-positive)]">
                {v.delta} from previous
              </p>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ── Live Embed ── */}
  <section class="border-b border-white/[0.06] bg-[var(--color-surface-1)]">
    <div class="mx-auto max-w-[90rem] px-6 py-8 lg:px-10">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-ink-2)]">
          Live Preview
        </h2>
        <div class="flex gap-1" id="route-tabs">
          {routes.map((r) => (
            <button
              data-route={r}
              class:list={[
                "route-tab rounded px-3 py-1.5 text-xs font-medium tabular-nums transition-colors",
                r === 1
                  ? "bg-[var(--color-accent)] text-[var(--color-surface-0)]"
                  : "bg-[var(--color-surface-3)] text-[var(--color-ink-2)] hover:text-[var(--color-ink-0)]",
              ]}
            >
              /{r}
            </button>
          ))}
        </div>
      </div>
      <div
        class="relative rounded-lg border border-white/[0.06]"
        style="height: 75vh;"
      >
        <iframe
          id="preview-frame"
          src={`/embeds/${v.slug}/index.html`}
          class="h-full w-full bg-white"
          style="border: none; display: block;"
          title={`${v.slug} live preview`}
          loading="lazy"
        />
        <div
          id="embed-fallback"
          class="absolute inset-0 hidden flex-col items-center justify-center gap-3 bg-[var(--color-surface-2)]"
        >
          <p class="text-sm text-[var(--color-ink-2)]">
            Live embed not available — run <code class="rounded bg-[var(--color-surface-3)] px-1.5 py-0.5 font-[var(--font-mono)] text-xs text-[var(--color-accent)]">bun run prepare</code> to build experiments.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Dimensions radar ── */}
  {v.dimensions && (
    <section class="border-b border-white/[0.06]">
      <div class="mx-auto max-w-[90rem] px-6 py-10 lg:px-10">
        <h2 class="mb-6 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-ink-2)]">
          Dimension Breakdown
        </h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
          {Object.entries(v.dimensions).map(([key, val]) => {
            const pct = (val / 2) * 100;
            return (
              <div class="rounded-lg border border-white/[0.04] bg-[var(--color-surface-1)] p-4">
                <div class="mb-2 flex items-center justify-between">
                  <span class="text-xs text-[var(--color-ink-2)]">
                    {dimensionLabels[key] ?? key}
                  </span>
                  <span
                    class:list={[
                      "text-sm font-bold tabular-nums",
                      val >= 1.7
                        ? "text-[var(--color-positive)]"
                        : val >= 1.3
                          ? "text-[var(--color-accent-glow)]"
                          : "text-[var(--color-ink-1)]",
                    ]}
                  >
                    {val.toFixed(1)}
                  </span>
                </div>
                <div class="h-1.5 overflow-hidden rounded-full bg-[var(--color-surface-3)]">
                  <div
                    class:list={[
                      "h-full rounded-full transition-all",
                      val >= 1.7
                        ? "bg-[var(--color-positive)]"
                        : val >= 1.3
                          ? "bg-[var(--color-accent)]"
                          : "bg-[var(--color-ink-2)]",
                    ]}
                    style={`width: ${pct}%;`}
                  />
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* ── Screenshot gallery ── */}
  <section class="mx-auto max-w-[90rem] px-6 py-10 lg:px-10">
    <h2 class="mb-6 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-ink-2)]">
      Route Screenshots
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {routes.map((r) => (
        <button
          data-lightbox-trigger
          data-index={r - 1}
          class="group cursor-zoom-in overflow-hidden rounded-lg border border-white/[0.06] bg-[var(--color-surface-1)] text-left transition-all hover:border-[var(--color-accent)]/30"
        >
          <div class="relative aspect-[9/16] overflow-hidden bg-[var(--color-surface-2)]">
            <img
              src={screenshotPath(v, r)}
              alt={`Route ${r} screenshot`}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
            />
          </div>
          <div class="px-3 py-2 text-center text-xs font-medium tabular-nums text-[var(--color-ink-2)]">
            Route /{r}
          </div>
        </button>
      ))}
    </div>
  </section>

  {/* ── Lightbox overlay ── */}
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Screenshot viewer"
  >
    {/* close button */}
    <button
      id="lb-close"
      class="absolute right-4 top-4 z-10 flex size-10 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white"
      aria-label="Close"
    >
      <svg class="size-5" viewBox="0 0 20 20" fill="none">
        <path d="M6 6l8 8M14 6l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    {/* prev arrow */}
    <button
      id="lb-prev"
      class="absolute left-4 top-1/2 z-10 flex size-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white"
      aria-label="Previous screenshot"
    >
      <svg class="size-5" viewBox="0 0 20 20" fill="none">
        <path d="M12 15l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    {/* next arrow */}
    <button
      id="lb-next"
      class="absolute right-4 top-1/2 z-10 flex size-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white"
      aria-label="Next screenshot"
    >
      <svg class="size-5" viewBox="0 0 20 20" fill="none">
        <path d="M8 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    {/* image container */}
    <div class="flex max-h-[90vh] max-w-[90vw] flex-col items-center">
      <img
        id="lb-image"
        src=""
        alt=""
        class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl"
      />
      <p
        id="lb-caption"
        class="mt-3 text-sm font-medium tabular-nums text-white/60"
      ></p>
    </div>

    {/* dot indicators */}
    <div id="lb-dots" class="absolute bottom-6 left-1/2 flex -translate-x-1/2 gap-2">
      {routes.map((r) => (
        <button
          data-dot-index={r - 1}
          class="lb-dot size-2 rounded-full bg-white/30 transition-colors"
          aria-label={`View route ${r}`}
        />
      ))}
    </div>
  </div>

  {/* ── Prev / Next nav ── */}
  <section class="border-t border-white/[0.06]">
    <div class="mx-auto flex max-w-[90rem] items-stretch">
      {prev ? (
        <a
          href={`/versions/${prev.slug}`}
          class="flex flex-1 items-center gap-3 border-r border-white/[0.06] px-6 py-6 transition-colors hover:bg-[var(--color-surface-1)] lg:px-10"
        >
          <svg class="size-4 shrink-0 text-[var(--color-ink-2)]" viewBox="0 0 16 16" fill="none">
            <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <div>
            <p class="text-[10px] uppercase tracking-wider text-[var(--color-ink-2)]">Previous</p>
            <p class="text-sm font-medium text-[var(--color-ink-0)]">{prev.slug}</p>
          </div>
        </a>
      ) : (
        <div class="flex-1" />
      )}
      {next ? (
        <a
          href={`/versions/${next.slug}`}
          class="flex flex-1 items-center justify-end gap-3 px-6 py-6 text-right transition-colors hover:bg-[var(--color-surface-1)] lg:px-10"
        >
          <div>
            <p class="text-[10px] uppercase tracking-wider text-[var(--color-ink-2)]">Next</p>
            <p class="text-sm font-medium text-[var(--color-ink-0)]">{next.slug}</p>
          </div>
          <svg class="size-4 shrink-0 text-[var(--color-ink-2)]" viewBox="0 0 16 16" fill="none">
            <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </a>
      ) : (
        <div class="flex-1" />
      )}
    </div>
  </section>

  <script define:vars={{ slug: v.slug }}>
    document.addEventListener("DOMContentLoaded", () => {
      const iframe = document.getElementById("preview-frame");
      const tabs = document.querySelectorAll(".route-tab");
      const fallback = document.getElementById("embed-fallback");

      // handle iframe load error
      iframe.addEventListener("error", () => {
        iframe.classList.add("hidden");
        fallback.classList.remove("hidden");
        fallback.classList.add("flex");
      });

      // route tab switching — navigate inside the iframe
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const route = tab.dataset.route;
          tabs.forEach((t) => {
            t.classList.remove(
              "bg-[var(--color-accent)]",
              "text-[var(--color-surface-0)]"
            );
            t.classList.add(
              "bg-[var(--color-surface-3)]",
              "text-[var(--color-ink-2)]"
            );
          });
          tab.classList.remove(
            "bg-[var(--color-surface-3)]",
            "text-[var(--color-ink-2)]"
          );
          tab.classList.add(
            "bg-[var(--color-accent)]",
            "text-[var(--color-surface-0)]"
          );

          try {
            iframe.contentWindow.location.hash = "";
            iframe.contentWindow.history.pushState(null, "", `/${route}`);
            iframe.contentWindow.dispatchEvent(new PopStateEvent("popstate"));
          } catch {
            // cross-origin fallback: reload entire iframe
            iframe.src = `/embeds/${slug}/index.html#/${route}`;
          }
        });
      });

      // ── Lightbox ──
      const lightbox = document.getElementById("lightbox");
      const lbImage = document.getElementById("lb-image");
      const lbCaption = document.getElementById("lb-caption");
      const lbClose = document.getElementById("lb-close");
      const lbPrev = document.getElementById("lb-prev");
      const lbNext = document.getElementById("lb-next");
      const dots = document.querySelectorAll(".lb-dot");
      const triggers = document.querySelectorAll("[data-lightbox-trigger]");

      // collect image sources from the trigger buttons
      const images = Array.from(triggers).map((t) => ({
        src: t.querySelector("img").src,
        alt: t.querySelector("img").alt,
      }));

      let current = 0;

      function show(index) {
        current = ((index % images.length) + images.length) % images.length;
        lbImage.src = images[current].src;
        lbImage.alt = images[current].alt;
        lbCaption.textContent = `Route /${current + 1}`;
        dots.forEach((d, i) => {
          d.classList.toggle("bg-white", i === current);
          d.classList.toggle("bg-white/30", i !== current);
        });
      }

      function open(index) {
        show(index);
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
        // fade in
        lightbox.animate(
          [{ opacity: 0 }, { opacity: 1 }],
          { duration: 150, easing: "ease-out" }
        );
      }

      function close() {
        lightbox.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          { duration: 120, easing: "ease-in" }
        ).onfinish = () => {
          lightbox.classList.add("hidden");
          lightbox.classList.remove("flex");
          document.body.style.overflow = "";
        };
      }

      // trigger clicks
      triggers.forEach((t) => {
        t.addEventListener("click", () => {
          open(parseInt(t.dataset.index, 10));
        });
      });

      // dot clicks
      dots.forEach((d) => {
        d.addEventListener("click", () => {
          show(parseInt(d.dataset.dotIndex, 10));
        });
      });

      lbClose.addEventListener("click", close);
      lbPrev.addEventListener("click", () => show(current - 1));
      lbNext.addEventListener("click", () => show(current + 1));

      // click backdrop to close
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) close();
      });

      // keyboard nav
      document.addEventListener("keydown", (e) => {
        if (lightbox.classList.contains("hidden")) return;
        if (e.key === "Escape") close();
        if (e.key === "ArrowLeft") show(current - 1);
        if (e.key === "ArrowRight") show(current + 1);
      });
    });
  </script>
</Base>
