# Google Forms endpoint copied from your form's "formResponse" URL.
PUBLIC_GOOGLE_FORM_ACTION="https://docs.google.com/forms/d/e/<FORM_ID>/formResponse"

# Google Forms entry ids for each field.
PUBLIC_GOOGLE_FORM_VERSION_FIELD="entry.1111111111"
PUBLIC_GOOGLE_FORM_ROUTE_FIELD="entry.2222222222"
PUBLIC_GOOGLE_FORM_VOTE_FIELD="entry.3333333333"
PUBLIC_GOOGLE_FORM_FEEDBACK_FIELD="entry.4444444444"
